# ============================================================
# Brain System — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.
# ============================================================

# YouTube Data API v3 key
# Get one free at: https://console.cloud.google.com
# Enable "YouTube Data API v3" for your project
YOUTUBE_API_KEY=your_youtube_api_key_here

# OpenRouter API key
# Sign up at: https://openrouter.ai
# Used for both ingestion summarisation and MCP query responses
OPENROUTER_API_KEY=your_openrouter_api_key_here

# OpenRouter model to use
# Cheap fast options:  google/gemini-flash-1.5  |  meta-llama/llama-3.1-8b-instruct
# Better quality:      anthropic/claude-3-5-haiku  |  openai/gpt-4o-mini
OPENROUTER_MODEL=google/gemini-flash-1.5

# Secret token for MCP server auth
# Generate one with: python -c "import secrets; print(secrets.token_urlsafe(32))"
# Add this same token to Claude.ai when registering the connector
MCP_AUTH_TOKEN=your_secret_token_here

# GitHub repo for committing brain files (format: username/repo-name)
# Only needed when running ingestion locally (GitHub Actions sets this automatically)
GITHUB_REPO=yourusername/brain-system

# GitHub personal access token
# Only needed when running ingestion locally
# Create at: github.com/settings/tokens (needs repo write scope)
GITHUB_TOKEN=your_github_token_here
